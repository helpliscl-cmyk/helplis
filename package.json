{
  "name": "helplis",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "vercel:build": "tsx scripts/vercel-build.ts",
    "start": "next start",
    "lint": "eslint",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "db:migrate": "prisma generate && tsx scripts/db-migrate.ts",
    "db:reset": "tsx scripts/db-reset.ts",
    "db:seed": "prisma db seed",
    "db:studio": "prisma studio",
    "generate:batch": "tsx scripts/generate-batch.ts",
    "import:batch": "tsx scripts/import-batch.ts",
    "export:batch": "tsx scripts/export-batch.ts",
    "verify:batch": "tsx scripts/verify-batch.ts",
    "production:generate": "tsx scripts/production-generate.ts",
    "production:export": "tsx scripts/production-export.ts",
    "production:verify": "tsx scripts/production-verify.ts",
    "production:import-uid": "tsx scripts/production-import-uid.ts",
    "typecheck": "tsc --noEmit"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "iron-session": "^8.0.4",
    "jszip": "^3.10.1",
    "lucide-react": "^1.24.0",
    "next": "16.2.10",
    "qrcode": "^1.5.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "sharp": "^0.35.3",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/pngjs": "^6.0.5",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/ui": "^4.1.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "jsdom": "^29.1.1",
    "jsqr": "^1.4.0",
    "pngjs": "^7.0.0",
    "prettier": "^3.9.5",
    "prisma": "^6.19.3",
    "tailwindcss": "^4",
    "tsx": "^4.23.0",
    "typescript": "^5",
    "vitest": "^4.1.10"
  }
