  PROFILE_VIEWED
  LINK_COPIED
}

enum ContactType {
  PRIMARY
  SECONDARY
}

enum ContactRelationship {
  MOTHER
  FATHER
  FAMILY
  RESPONSIBLE
}

enum ImportJobStatus {
  DRAFT
  VALIDATED
  IMPORTED
  FAILED
}

enum SupportMessageStatus {
  NEW
  REVIEWED
  RESOLVED
  ARCHIVED
}

model User {
  id                 String                   @id @default(cuid())
  email              String                   @unique
  phone              String?
  name               String
  passwordHash       String
  role               UserRole                 @default(USER)
  status             UserStatus               @default(PENDING)
  emailVerifiedAt    DateTime?
  phoneVerifiedAt    DateTime?
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt
  lastLoginAt        DateTime?
  deletedAt          DateTime?
  devices            Device[]                 @relation("DeviceOwner")
  profiles           Profile[]
  activations        Activation[]
  memberships        OrganizationMembership[]
  notificationEvents NotificationEvent[]
  auditLogs          AuditLog[]               @relation("AuditActor")
  supportMessages    SupportMessage[]
  orders             Order[]
  supportTickets     SupportTicket[]          @relation("SupportTicketUser")
  assignedTickets    SupportTicket[]          @relation("SupportTicketAssignee")

  @@index([role])
  @@index([status])
}

model Device {
  id                      String                   @id @default(cuid())
  internalSequence        Int?
  publicCode              String                   @unique
  publicUrl               String                   @unique
  qrContent               String?
  nfcContent              String?
  nfcUid                  String?                  @unique
  activationCodeHash      String
  activationCodeEncrypted String?
  activationCodeUsedAt    DateTime?
  activationAttempts      Int                      @default(0)
  activationBlockedUntil  DateTime?
  batchId                 String?
  productType             ProductType              @default(WRISTBAND)
  status                  DeviceStatus             @default(AVAILABLE)
  ownerId                 String?
  profileId               String?
  organizationId          String?
  inventoryLocationId     String?
  productionStatus        DeviceProductionStatus   @default(DRAFT)
  verificationStatus      DeviceVerificationStatus @default(PENDING)
  inventoryStatus         InventoryStatus          @default(IN_PRODUCTION)
  activatedAt             DateTime?
  reservedAt              DateTime?
  soldAt                  DateTime?
  packedAt                DateTime?
  shippedAt               DateTime?
  deliveredAt             DateTime?
  suspendedAt             DateTime?
  deactivatedAt           DateTime?
  replacedById            String?
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  deletedAt               DateTime?
  batch                   Batch?                   @relation(fields: [batchId], references: [id])
  owner                   User?                    @relation("DeviceOwner", fields: [ownerId], references: [id])
  profile                 Profile?                 @relation(fields: [profileId], references: [id])
  organization            Organization?            @relation(fields: [organizationId], references: [id])
  inventoryLocation       InventoryLocation?       @relation(fields: [inventoryLocationId], references: [id])
  replacedBy              Device?                  @relation("Replacement", fields: [replacedById], references: [id])
  replacements            Device[]                 @relation("Replacement")
  scanEvents              ScanEvent[]
  activations             Activation[]
  notificationEvents      NotificationEvent[]
  contactActions          ContactAction[]
  locationShares          LocationShare[]
  foundReports            FoundReport[]
  physicalVerifications   PhysicalVerification[]
  orderItems              OrderItem[]
  supportTickets          SupportTicket[]

  @@index([status])
  @@index([productionStatus])
  @@index([verificationStatus])
  @@index([inventoryStatus])
  @@index([productType])
  @@index([batchId])
  @@index([ownerId])
  @@index([profileId])
  @@index([organizationId])
  @@index([inventoryLocationId])
}

model Profile {
  id                      String              @id @default(cuid())
  ownerId                 String?
  type                    ProfileType         @default(PERSON)
  displayName             String
  legalName               String?
  alias                   String?
  photoUrl                String?
  photoStoragePath        String?
  photoMimeType           String?
  photoWidth              Int?
  photoHeight             Int?
  photoSizeBytes          Int?
  photoUpdatedAt          DateTime?
  headline                String?
  helpMessage             String?
  description             String?
  statusMessage           String?
  firstName               String?
  lastName                String?
  approximateAge          Int?
  genderOptional          String?
  communicationNotes      String?
  mobilityNotes           String?
  sensoryNotes            String?
  cognitiveNotes          String?
  medicalNotes            String?
  allergies               String?
  medicalConditions       String?
  medications             String?
  bloodType               String?
  medicalInstructions     String?
  emergencyInstructions   String?
  criticalInformation     String?
  organDonorOptional      Boolean?
  healthProviderOptional  String?
  specialInstructions     String?
  preferredLanguage       String              @default("es")
  birthYear               Int?
  country                 String?
  region                  String?
  commune                 String?
  generalArea             String?
  exactAddress            String?
  species                 String?
  petName                 String?
  breed                   String?
  color                   String?
  sex                     String?
  sterilizedOptional      Boolean?
  veterinaryNotes         String?
  microchipNumberOptional String?
  petBehaviorNotes        String?
  objectName              String?
  objectCategory          String?
  brand                   String?
  model                   String?
  objectDescription       String?
  rewardMessage           String?
  returnInstructions      String?
  lostMessage             String?
  showPhoto               Boolean             @default(true)
  showDisplayName         Boolean             @default(true)
  showFullName            Boolean             @default(false)
  showAlias               Boolean             @default(true)
  showCriticalInformation Boolean             @default(false)
  showMedicalInfo         Boolean             @default(false)
  showContactNames        Boolean             @default(true)
  showPhoneNumbers        Boolean             @default(false)
  showAge                 Boolean             @default(false)
  showApproximateAge      Boolean             @default(false)
  showBloodType           Boolean             @default(false)
  showAllergies           Boolean             @default(false)
  showMedicalConditions   Boolean             @default(false)
  showMedications         Boolean             @default(false)
  showMedicalInstructions Boolean             @default(false)
  showCommunicationNotes  Boolean             @default(false)
  showMobilityNotes       Boolean             @default(false)
  showSensoryNotes        Boolean             @default(false)
  showGeneralArea         Boolean             @default(false)
  showExactAddress        Boolean             @default(false)
  showLocationButton      Boolean             @default(true)
  showWhatsAppButton      Boolean             @default(true)
  showCallButton          Boolean             @default(true)
  showMessageButton       Boolean             @default(true)
  allowCall               Boolean             @default(true)
  allowWhatsApp           Boolean             @default(true)
  allowMessage            Boolean             @default(true)
  allowLocationSharing    Boolean             @default(true)
  allowFoundReport        Boolean             @default(true)
  isPublic                Boolean             @default(true)
  createdAt               DateTime            @default(now())
  updatedAt               DateTime            @updatedAt
  deletedAt               DateTime?
  owner                   User?               @relation(fields: [ownerId], references: [id])
  devices                 Device[]
  contacts                EmergencyContact[]
  scanEvents              ScanEvent[]
  notificationEvents      NotificationEvent[]
  contactActions          ContactAction[]
  locationShares          LocationShare[]
  foundReports            FoundReport[]

  @@index([ownerId])
  @@index([type])
  @@index([isPublic])
}

model EmergencyContact {
  id                String               @id @default(cuid())
  profileId         String
  type              ContactType          @default(PRIMARY)
  name              String
  relationship      String?
  relationshipCode  ContactRelationship?
  phone             String
  email             String?
  availabilityNotes String?
  whatsappEnabled   Boolean              @default(true)
  callEnabled       Boolean              @default(true)
  messageEnabled    Boolean              @default(true)
  priority          Int                  @default(1)
  isVisible         Boolean              @default(true)
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  profile           Profile              @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId])
  @@index([type])
  @@index([priority])
}

model ScanEvent {
  id                 String              @id @default(cuid())
  deviceId           String
  profileId          String?
  scannedAt          DateTime            @default(now())
  scanMethod         ScanMethod          @default(UNKNOWN)
  ipHash             String?
  userAgent          String?
  deviceType         String?
  browser            String?
  operatingSystem    String?
  country            String?
  region             String?
  city               String?
  latitude           Float?
  longitude          Float?
  locationAccuracy   Float?
  locationPermission Boolean             @default(false)
  locationSharedAt   DateTime?
  referrer           String?
  sessionId          String?
  eventStatus        ScanEventStatus     @default(RECORDED)
  createdAt          DateTime            @default(now())
  device             Device              @relation(fields: [deviceId], references: [id])
  profile            Profile?            @relation(fields: [profileId], references: [id])
  notificationEvents NotificationEvent[]
  contactActions     ContactAction[]
  locationShares     LocationShare[]
  foundReports       FoundReport[]

  @@index([deviceId])
  @@index([profileId])
  @@index([scannedAt])
  @@index([scanMethod])
}

model LocationShare {
  id               String     @id @default(cuid())
  deviceId         String
  profileId        String?
  scanEventId      String?
  latitude         Float?
  longitude        Float?
  accuracy         Float?
  consented        Boolean    @default(false)
  permissionStatus String     @default("GRANTED")
  result           String     @default("RECORDED")
  ipHash           String?
  userAgent        String?
  createdAt        DateTime   @default(now())
  device           Device     @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  profile          Profile?   @relation(fields: [profileId], references: [id], onDelete: SetNull)
  scanEvent        ScanEvent? @relation(fields: [scanEventId], references: [id], onDelete: SetNull)

  @@index([deviceId])
  @@index([profileId])
  @@index([scanEventId])
  @@index([createdAt])
  @@index([permissionStatus])
}

model FoundReport {
  id                String     @id @default(cuid())
  deviceId          String
  profileId         String?
  scanEventId       String?
  reporterName      String?
  reporterPhone     String?
  message           String?
  latitude          Float?
  longitude         Float?
  accuracy          Float?
  consentedLocation Boolean    @default(false)
  status            String     @default("RECEIVED")
  ipHash            String?
  userAgent         String?
  createdAt         DateTime   @default(now())
  device            Device     @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  profile           Profile?   @relation(fields: [profileId], references: [id], onDelete: SetNull)
  scanEvent         ScanEvent? @relation(fields: [scanEventId], references: [id], onDelete: SetNull)

  @@index([deviceId])
  @@index([profileId])
  @@index([scanEventId])
  @@index([createdAt])
  @@index([status])
}

model Activation {
  id           String           @id @default(cuid())
  deviceId     String
  userId       String?
  status       ActivationStatus @default(PENDING)
  startedAt    DateTime         @default(now())
  completedAt  DateTime?
  expiresAt    DateTime?
  ipHash       String?
  userAgent    String?
  attemptCount Int              @default(0)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  device       Device           @relation(fields: [deviceId], references: [id])
  user         User?            @relation(fields: [userId], references: [id])

  @@index([deviceId])
  @@index([userId])
  @@index([status])
}

model Batch {
  id                     String                 @id @default(cuid())
  supplierName           String
  supplierContact        String?
  supplierReference      String?
  supplierQuoteReference String?
  internalReference      String                 @unique
  productModel           String?
  productType            ProductType            @default(WRISTBAND)
  color                  String?
  chipType               String?
  domain                 String                 @default("https://helplis.cl")
  productionMode         ProductionMode         @default(DEMO)
  quantity               Int
  receivedQuantity       Int                    @default(0)
  productionDate         DateTime?
  sentToSupplierAt       DateTime?
  productionStartedAt    DateTime?
  productionCompletedAt  DateTime?
  shippedAt              DateTime?
  receivedAt             DateTime?
  verifiedAt             DateTime?
  shippingMethod         String?
  status                 BatchStatus            @default(DRAFT)
  notes                  String?
  createdBy              String?
  createdAt              DateTime               @default(now())
  updatedAt              DateTime               @updatedAt
  devices                Device[]
  importJobs             ImportJob[]
  productionFiles        ProductionFile[]
  supplierUidImports     SupplierUidImport[]
  physicalVerifications  PhysicalVerification[]
  supportTickets         SupportTicket[]

  @@index([status])
  @@index([productionMode])
  @@index([productType])
}

model Organization {
  id                     String                   @id @default(cuid())
  name                   String
  type                   OrganizationType         @default(OTHER)
  slug                   String                   @unique
  contactName            String?
  contactEmail           String?
  contactPhone           String?
  status                 OrganizationStatus       @default(PENDING)
  discountCode           String?
  discountPercentage     Float                    @default(0)
  commissionPercentage   Float                    @default(0)
  landingTitle           String?
  landingDescription     String?
  establishmentId        String?                  @unique
  holderId               String?
  commercialStatus       CommercialStatus         @default(SIN_REVISAR)
  priority               Int                      @default(0)
  assignedTo             String?
  lastContactAt          DateTime?
  nextActionAt           DateTime?
  doNotContact           Boolean                  @default(false)
  prospectScore          Int                      @default(0)
  prospectScoreBreakdown String?
  prospectNotes          String?
  createdAt              DateTime                 @default(now())
  updatedAt              DateTime                 @updatedAt
  establishment          Establishment?           @relation(fields: [establishmentId], references: [id])
  holder                 Holder?                  @relation(fields: [holderId], references: [id])
  devices                Device[]
  memberships            OrganizationMembership[]
  campaigns              Campaign[]
  importJobs             ImportJob[]
  institutionLeads       InstitutionLead[]
  supportTickets         SupportTicket[]
  opportunities          Opportunity[]
  activities             Activity[]

  @@index([status])
  @@index([type])
  @@index([commercialStatus])
  @@index([holderId])
  @@index([nextActionAt])
}

model OrganizationMembership {
  id             String           @id @default(cuid())
  organizationId String
  userId         String
  role           MembershipRole   @default(VIEWER)
  status         MembershipStatus @default(ACTIVE)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([userId])
  @@index([role])
}

model Campaign {
  id                   String         @id @default(cuid())
  organizationId       String
  name                 String
  slug                 String
  description          String?
  discountCode         String?
  discountPercentage   Float          @default(0)
  commissionPercentage Float          @default(0)
  startAt              DateTime?
  endAt                DateTime?
  status               CampaignStatus @default(DRAFT)
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  organization         Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, slug])
  @@index([status])
}

model NotificationEvent {
  id           String                @id @default(cuid())
  userId       String?
  deviceId     String?
  profileId    String?
  scanEventId  String?
  channel      NotificationChannel   @default(LOCAL)
  eventType    NotificationEventType
  recipient    String?
  status       NotificationStatus    @default(SIMULATED)
  payload      String
  errorMessage String?
  scheduledAt  DateTime?
  sentAt       DateTime?
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
  user         User?                 @relation(fields: [userId], references: [id])
  device       Device?               @relation(fields: [deviceId], references: [id])
  profile      Profile?              @relation(fields: [profileId], references: [id])
  scanEvent    ScanEvent?            @relation(fields: [scanEventId], references: [id])

  @@index([eventType])
  @@index([channel])
  @@index([status])
  @@index([createdAt])
}

model AuditLog {
  id           String   @id @default(cuid())
  actorUserId  String?
  action       String
  entityType   String
  entityId     String?
  previousData String?
  newData      String?
  ipHash       String?
  userAgent    String?
  createdAt    DateTime @default(now())
  actor        User?    @relation("AuditActor", fields: [actorUserId], references: [id])

  @@index([actorUserId])
  @@index([entityType])
  @@index([createdAt])
}

model ContactAction {
  id          String            @id @default(cuid())
  deviceId    String?
  profileId   String?
  scanEventId String?
  action      ContactActionType
  metadata    String?
  ipHash      String?
  userAgent   String?
  createdAt   DateTime          @default(now())
  device      Device?           @relation(fields: [deviceId], references: [id])
  profile     Profile?          @relation(fields: [profileId], references: [id])
  scanEvent   ScanEvent?        @relation(fields: [scanEventId], references: [id])

  @@index([action])
  @@index([deviceId])
  @@index([profileId])
  @@index([createdAt])
}

model ImportJob {
  id             String          @id @default(cuid())
  batchId        String?
  organizationId String?
  filename       String
  status         ImportJobStatus @default(DRAFT)
  totalRows      Int             @default(0)
  validRows      Int             @default(0)
  invalidRows    Int             @default(0)
  errors         String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  batch          Batch?          @relation(fields: [batchId], references: [id])
  organization   Organization?   @relation(fields: [organizationId], references: [id])
  rows           ImportRow[]

  @@index([status])
}

model ImportRow {
  id          String       @id @default(cuid())
  importJobId String
  rowNumber   Int
  publicCode  String?
  publicUrl   String?
  nfcUid      String?
  productType ProductType?
  isValid     Boolean      @default(false)
  errors      String?
  rawData     String
  createdAt   DateTime     @default(now())
  importJob   ImportJob    @relation(fields: [importJobId], references: [id], onDelete: Cascade)

  @@index([importJobId])
  @@index([isValid])
}

model SupportMessage {
  id        String               @id @default(cuid())
  userId    String?
  name      String
  email     String
  phone     String?
  subject   String
  message   String
  status    SupportMessageStatus @default(NEW)
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt
  user      User?                @relation(fields: [userId], references: [id])

  @@index([status])
  @@index([createdAt])
}

model PurchaseIntent {
  id              String   @id @default(cuid())
  name            String
  phone           String
  email           String?
  commune         String
  region          String   @default("")
  packId          Int      @default(1)
  quantity        Int      @default(1)
  unitPrice       Int      @default(18000)
  totalPrice      Int      @default(18000)
  shippingPending Boolean  @default(true)
  primaryUse      String
  contactAccepted Boolean  @default(false)
  source          String?
  origin          String?
  message         String?
  status          String   @default("NEW")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  order           Order?

  @@index([status])
  @@index([packId])
  @@index([primaryUse])
  @@index([createdAt])
}

model AnalyticsEvent {
  id        String   @id @default(cuid())
  eventName String
  path      String?
  target    String?
  metadata  String?
  createdAt DateTime @default(now())

  @@index([eventName])
  @@index([createdAt])
}

model ProductionFile {
  id          String               @id @default(cuid())
  batchId     String
  type        ProductionFileType
  filename    String
  storagePath String
  checksum    String
  generatedAt DateTime             @default(now())
  generatedBy String?
  version     Int                  @default(1)
  status      ProductionFileStatus @default(GENERATED)
  metadata    String?
  batch       Batch                @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@index([batchId])
  @@index([type])
  @@index([status])
  @@index([generatedAt])
}

model SupplierUidImport {
  id              String                  @id @default(cuid())
  batchId         String
  filename        String
  status          SupplierUidImportStatus @default(DRAFT)
  totalRows       Int                     @default(0)
  validRows       Int                     @default(0)
  invalidRows     Int                     @default(0)
  duplicateRows   Int                     @default(0)
  importedRows    Int                     @default(0)
  errorReportPath String?
  mapping         String?
  preview         String?
  createdAt       DateTime                @default(now())
  completedAt     DateTime?
  createdBy       String?
  batch           Batch                   @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@index([batchId])
  @@index([status])
  @@index([createdAt])
}

model PhysicalVerification {
  id             String                   @id @default(cuid())
  deviceId       String
  batchId        String
  qrExpected     String
  qrObserved     String?
  nfcExpected    String
  nfcObserved    String?
  nfcUidExpected String?
  nfcUidObserved String?
  qrStatus       DeviceVerificationStatus @default(PENDING)
  nfcStatus      DeviceVerificationStatus @default(PENDING)
  uidStatus      DeviceVerificationStatus @default(PENDING)
  physicalStatus DeviceVerificationStatus @default(PENDING)
  overallStatus  DeviceVerificationStatus @default(PENDING)
  notes          String?
  photoUrl       String?
  verifiedBy     String?
  verifiedAt     DateTime?
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt
  device         Device                   @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  batch          Batch                    @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@index([deviceId])
  @@index([batchId])
  @@index([overallStatus])
  @@index([verifiedAt])
}

model InventoryLocation {
  id        String   @id @default(cuid())
  name      String
  warehouse String?
  shelf     String?
  box       String?
  position  String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  devices   Device[]

  @@index([name])
  @@index([warehouse])
}

model Order {
  id                String                 @id @default(cuid())
  orderNumber       String                 @unique
  leadId            String?                @unique
  userId            String?
  customerName      String
  phone             String
  email             String?
  region            String
  comuna            String
  address           String?
  addressNotes      String?
  pack              String
  quantity          Int
  unitPrice         Int
  subtotal          Int
  shippingCost      Int                    @default(0)
  total             Int
  paymentStatus     OrderPaymentStatus     @default(PENDING)
  fulfillmentStatus OrderFulfillmentStatus @default(NEW)
  source            String?
  notes             String?
  trackingNumber    String?
  carrier           String?
  paidAt            DateTime?
  packedAt          DateTime?
  shippedAt         DateTime?
  deliveredAt       DateTime?
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt
  lead              PurchaseIntent?        @relation(fields: [leadId], references: [id])
  user              User?                  @relation(fields: [userId], references: [id])
  items             OrderItem[]
  payments          Payment[]
  shipments         Shipment[]
  supportTickets    SupportTicket[]

  @@index([paymentStatus])
  @@index([fulfillmentStatus])
  @@index([createdAt])
  @@index([leadId])
  @@index([userId])
}

model OrderItem {
  id          String          @id @default(cuid())
  orderId     String
  deviceId    String?
  productType ProductType     @default(WRISTBAND)
  unitPrice   Int
  status      OrderItemStatus @default(PENDING)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  order       Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  device      Device?         @relation(fields: [deviceId], references: [id])

  @@index([orderId])
  @@index([deviceId])
  @@index([status])
}

model Payment {
  id                String              @id @default(cuid())
  orderId           String
  provider          PaymentProviderType @default(MANUAL)
  method            PaymentMethod       @default(TRANSFER)
  amount            Int
  currency          String              @default("CLP")
  status            PaymentStatus       @default(PENDING)
  externalReference String?
  proofUrl          String?
  reportedAt        DateTime?
  approvedAt        DateTime?
  rejectedAt        DateTime?
  notes             String?
  createdBy         String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  order             Order               @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([provider])
  @@index([status])
  @@index([createdAt])
}

model Shipment {
  id                  String         @id @default(cuid())
  orderId             String
  provider            String         @default("MANUAL")
  carrier             String?
  service             String?
  trackingNumber      String?
  cost                Int            @default(0)
  status              ShipmentStatus @default(DRAFT)
  shippedAt           DateTime?
  estimatedDeliveryAt DateTime?
  deliveredAt         DateTime?
  notes               String?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  order               Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([status])
  @@index([trackingNumber])
}

model InstitutionLead {
  id                   String                @id @default(cuid())
  organizationId       String?
  institutionName      String
  type                 String
  region               String
  comuna               String
  contactName          String
  contactRole          String?
  phone                String
  email                String
  estimatedQuantity    Int
  estimatedDate        DateTime?
  interest             String
  notes                String?
  status               InstitutionLeadStatus @default(NEW)
  landingSlug          String?
  institutionalCode    String?
  discountPercentage   Float                 @default(0)
  commissionPercentage Float                 @default(0)
  metrics              String?
  documents            String?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  organization         Organization?         @relation(fields: [organizationId], references: [id])

  @@index([status])
  @@index([type])
  @@index([createdAt])
  @@index([organizationId])
}

model Establishment {
  id                      String                @id @default(cuid())
  rbd                     Int                   @unique
  name                    String?
  status                  String?
  region                  String?
  province                String?
  commune                 String?
  address                 String?
  latitude                Float?
  longitude               Float?
  dependency              String?
  officialRecognition     String?
  educationLevels         String?
  totalEnrollment         Int?
  averageStudentsPerCourse Float?
  directorName            String?
  holderName              String?
  holderId                String?
  phone                   String?
  contactEmail            String?
  website                 String?
  mimeUrl                 String
  source                  String                @default("MIME_MINEDUC")
  sourceCheckedAt         DateTime?
  sourceChangedAt         DateTime?
  contentHash             String?
  extraData               String?
  createdAt               DateTime              @default(now())
  updatedAt               DateTime              @updatedAt
  holder                  Holder?               @relation(fields: [holderId], references: [id], onDelete: SetNull)
  contacts                Contact[]
  scrapeAttempts          ScrapeAttempt[]
  commercialOrganizations Organization[]
  suppressions            Suppression[]
  changes                 EstablishmentChange[]

  @@index([region])
  @@index([commune])
  @@index([dependency])
  @@index([status])
  @@index([holderId])
  @@index([sourceCheckedAt])
}

model Holder {
  id                      String          @id @default(cuid())
  normalizedName          String          @unique
  originalName            String
  type                    String?
  website                 String?
  primaryEmail            String?
  primaryPhone            String?
  createdAt               DateTime        @default(now())
  updatedAt               DateTime        @updatedAt
  establishments          Establishment[]
  contacts                Contact[]
  commercialOrganizations Organization[]

  @@index([type])
  @@index([primaryEmail])
}

model Contact {
  id              String             @id @default(cuid())
  establishmentId String?
  holderId        String?
  name            String?
  role            String?
  email           String?
  phone           String?
  contactType     String?
  label           String?
  section         String?
  source          String             @default("MIME_MINEDUC")
  sourceUrl       String?
  verifiedAt      DateTime?
  emailStatus     ContactEmailStatus @default(UNKNOWN)
  doNotContact    Boolean            @default(false)
  notes           String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  establishment   Establishment?     @relation(fields: [establishmentId], references: [id], onDelete: SetNull)
  holder          Holder?            @relation(fields: [holderId], references: [id], onDelete: SetNull)
  activities      Activity[]

  @@index([establishmentId])
  @@index([holderId])
  @@index([email])
  @@index([doNotContact])
}

model ScrapeJob {
  id              String            @id @default(cuid())
  type            MimeScrapeJobType
  status          ScrapeJobStatus   @default(DRAFT)
  totalItems      Int               @default(0)
  processedItems  Int               @default(0)
  successfulItems Int               @default(0)
  failedItems     Int               @default(0)
  skippedItems    Int               @default(0)
  startedAt       DateTime?
  finishedAt      DateTime?
  lastHeartbeatAt DateTime?
  configuration   String
  lockOwner       String?
  lockedAt        DateTime?
  pauseReason     String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  attempts        ScrapeAttempt[]

  @@index([type])
  @@index([status])
  @@index([lastHeartbeatAt])
}

model ScrapeAttempt {
  id              String              @id @default(cuid())
  jobId           String
  establishmentId String?
  rbd             Int
  url             String
  requestedUrl    String?
  finalUrl        String?
  redirected      Boolean            @default(false)
  contentType     String?
  status          ScrapeAttemptStatus @default(PENDING)
  httpStatus      Int?
  attemptNumber   Int                 @default(1)
  errorType       String?
  errorMessage    String?
  startedAt       DateTime?
  finishedAt      DateTime?
  nextRetryAt     DateTime?
  job             ScrapeJob           @relation(fields: [jobId], references: [id], onDelete: Cascade)
  establishment   Establishment?      @relation(fields: [establishmentId], references: [id], onDelete: SetNull)

  @@index([jobId])
  @@index([establishmentId])
  @@index([rbd])
  @@index([status])
  @@index([nextRetryAt])
}

model Opportunity {
  id              String           @id @default(cuid())
  organizationId  String
  stage           CommercialStatus @default(SIN_REVISAR)
  estimatedValue  Int?
  probability     Int?
  productInterest String?
  source          String?
  nextActionAt    DateTime?
  lostReason      String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  organization    Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  activities      Activity[]

  @@index([organizationId])
  @@index([stage])
  @@index([nextActionAt])
}

model Activity {
  id             String       @id @default(cuid())
  organizationId String
  contactId      String?
  opportunityId  String?
  type           String
  direction      String?
  subject        String?
  body           String?
  occurredAt     DateTime
  createdBy      String?
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  contact        Contact?     @relation(fields: [contactId], references: [id], onDelete: SetNull)
  opportunity    Opportunity? @relation(fields: [opportunityId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([contactId])
  @@index([opportunityId])
  @@index([occurredAt])
}

model Suppression {
  id              String         @id @default(cuid())
  email           String?
  domain          String?
  establishmentId String?
  reason          String
  source          String?
  createdAt       DateTime       @default(now())
  establishment   Establishment? @relation(fields: [establishmentId], references: [id], onDelete: SetNull)

  @@index([email])
  @@index([domain])
  @@index([establishmentId])
}

model EstablishmentChange {
  id              String        @id @default(cuid())
  establishmentId String
  source          String        @default("MIME_MINEDUC")
  sourceUrl       String?
  changedFields   String
  previousData    String?
  newData         String?
  contentHash     String?
  createdAt       DateTime      @default(now())
  establishment   Establishment @relation(fields: [establishmentId], references: [id], onDelete: Cascade)

  @@index([establishmentId])
  @@index([createdAt])
}

model SupportTicket {
  id             String                @id @default(cuid())
  userId         String?
  orderId        String?
  deviceId       String?
  batchId        String?
  organizationId String?
  category       SupportTicketCategory @default(OTHER)
  status         SupportTicketStatus   @default(OPEN)
  priority       SupportTicketPriority @default(NORMAL)
  subject        String
  description    String
  assignedTo     String?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  resolvedAt     DateTime?
  user           User?                 @relation("SupportTicketUser", fields: [userId], references: [id])
  assignee       User?                 @relation("SupportTicketAssignee", fields: [assignedTo], references: [id])
  order          Order?                @relation(fields: [orderId], references: [id])
  device         Device?               @relation(fields: [deviceId], references: [id])
  batch          Batch?                @relation(fields: [batchId], references: [id])
  organization   Organization?         @relation(fields: [organizationId], references: [id])

  @@index([status])
  @@index([priority])
  @@index([category])
  @@index([orderId])
  @@index([deviceId])
  @@index([batchId])
  @@index([organizationId])
}
